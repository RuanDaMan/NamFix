@using NamFix.SharedUi.Layout
@using NamFix.SharedUi.Pages
@*
    Routable components live in the NamFix.SharedUi RCL so a future MAUI host reuses them.
    AdditionalAssemblies pulls those routes into this host's router.
*@
<CascadingAuthenticationState>
    <Router AppAssembly="@typeof(App).Assembly"
            AdditionalAssemblies="new[] { typeof(NamFix.SharedUi.Pages.Home).Assembly }">
        <Found Context="routeData">
            <AuthorizeRouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)">
                <NotAuthorized>
                    <div class="nf-main">
                        <p>You need to <a href="login">log in</a> to view this page.</p>
                    </div>
                </NotAuthorized>
            </AuthorizeRouteView>
            <FocusOnNavigate RouteData="@routeData" Selector="h1" />
        </Found>
        <NotFound>
            <LayoutView Layout="@typeof(MainLayout)">
                <p class="nf-main">Page not found.</p>
            </LayoutView>
        </NotFound>
    </Router>
</CascadingAuthenticationState>
