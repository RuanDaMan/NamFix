@implements IDisposable
@inject NamFixApiClient Api
@inject NavigationManager Nav
@inject ThemeService Theme
@inject NotificationService Notifications
@inject AuthenticationStateProvider AuthProvider

<nav class="nf-nav">
    <a class="nf-brand" href="" @onclick="CloseMenu">
        <svg class="nf-brand-mark" viewBox="0 0 100 100" aria-hidden="true" focusable="false">
            <circle cx="50" cy="50" r="42" fill="none" stroke="currentColor" stroke-width="8" />
            <g transform="rotate(15 50 50)" fill="var(--nf-accent)">
                <rect x="45" y="16" width="10" height="68" rx="4" />
                <rect x="16" y="45" width="68" height="10" rx="4" />
            </g>
        </svg>
        <span>Nam<span class="nf-brand-fix">Fix</span></span>
    </a>

    <div class="nf-nav-links @(_menuOpen ? "open" : "")">
        <ConnectionStatus />
        <button class="nf-theme-toggle" type="button" @onclick="ToggleThemeAsync"
                title="@(Theme.IsDark ? "Switch to light mode" : "Switch to dark mode")"
                aria-label="@(Theme.IsDark ? "Switch to light mode" : "Switch to dark mode")">
            @(Theme.IsDark ? "☀️" : "🌙")
        </button>
        <a href="">Search</a>
        <AuthorizeView Roles="Client">
            <a href="post-job">Get matched</a>
        </AuthorizeView>
        <AuthorizeView Roles="ServiceProvider">
            <a href="profile">My Profile</a>
            <a href="open-jobs">
                Job board
                @if (_openJobCount > 0)
                {
                    <span class="nf-nav-badge">@(_openJobCount > 9 ? "9+" : _openJobCount.ToString())</span>
                }
            </a>
        </AuthorizeView>
        <AuthorizeView Roles="Admin">
            <a href="admin">Admin</a>
            <a href="admin/tickets">Tickets</a>
            <a href="admin/inbox">Inbox</a>
            <a href="admin/users">Users</a>
        </AuthorizeView>
        <AuthorizeView>
            <Authorized>
                <a href="bookings">Bookings</a>
                <a href="support">Support</a>
                <a href="settings/email">Email settings</a>
                <NotificationsBell />
                <span class="nf-user">Hi, @context.User.Identity?.Name</span>
                <button class="nf-link-btn" @onclick="LogoutAsync">Log out</button>
            </Authorized>
            <NotAuthorized>
                <a class="nf-cta" href="login">Log in / Sign up</a>
            </NotAuthorized>
        </AuthorizeView>
    </div>

    @* Mobile top-bar controls (hidden on desktop). The bell lives here rather than in the drawer so
       notifications are one tap away and its panel drops from the top bar (no transformed ancestor,
       so it can render as a full-width sheet). The desktop bell stays inline in .nf-nav-links. *@
    <div class="nf-nav-mobile">
        <AuthorizeView>
            <Authorized>
                <NotificationsBell />
            </Authorized>
            <NotAuthorized>
                <a class="nf-nav-auth" href="login" aria-label="Log in or sign up" title="Log in or sign up">👤</a>
            </NotAuthorized>
        </AuthorizeView>
        <button class="nf-hamburger" type="button"
                @onclick="ToggleMenu" aria-label="Menu" aria-expanded="@(_menuOpen ? "true" : "false")">
            <span></span><span></span><span></span>
        </button>
    </div>

    @* Backdrop behind the mobile drawer; tapping it closes the menu. Kept INSIDE <nav> so it shares
       the drawer's stacking context — otherwise the sticky nav's own stacking context traps the
       drawer beneath a root-level backdrop and swallows taps on the links. *@
    <div class="nf-nav-backdrop @(_menuOpen ? "open" : "")" @onclick="CloseMenu"></div>
</nav>

@code {
    private bool _menuOpen;
    private bool _isProvider;
    private int _openJobCount;

    protected override void OnInitialized()
    {
        // Close the drawer whenever navigation happens (covers taps on any nav link).
        Nav.LocationChanged += OnLocationChanged;
        // Re-evaluate the provider job-board badge whenever auth changes (login/logout in-session).
        AuthProvider.AuthenticationStateChanged += OnAuthChanged;
    }

    protected override async Task OnInitializedAsync() =>
        await ApplyAuthAsync(await AuthProvider.GetAuthenticationStateAsync());

    private void OnAuthChanged(Task<AuthenticationState> state) => _ = InvokeAsync(async () => await ApplyAuthAsync(await state));

    private async Task ApplyAuthAsync(AuthenticationState state)
    {
        var isProvider = state.User.IsInRole("ServiceProvider");
        if (isProvider == _isProvider) return;
        _isProvider = isProvider;

        if (_isProvider)
        {
            // Live badge of open jobs the provider can respond to; refresh on any realtime event.
            Notifications.NotificationsChanged += OnJobsMaybeChanged;
            Notifications.BookingChanged += OnBookingChanged;
            await RefreshOpenJobCountAsync();
        }
        else
        {
            Notifications.NotificationsChanged -= OnJobsMaybeChanged;
            Notifications.BookingChanged -= OnBookingChanged;
            _openJobCount = 0;
            StateHasChanged();
        }
    }

    private void OnJobsMaybeChanged() => _ = InvokeAsync(RefreshOpenJobCountAsync);
    private void OnBookingChanged(Guid jobId) => _ = InvokeAsync(RefreshOpenJobCountAsync);

    private async Task RefreshOpenJobCountAsync()
    {
        if (!_isProvider) return;
        var jobs = await Api.GetOpenJobsAsync();
        var count = jobs.Count;
        if (count != _openJobCount)
        {
            _openJobCount = count;
            StateHasChanged();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Sync C# theme state with what the inline script already applied, then render the icon.
            await Theme.InitializeAsync();
            StateHasChanged();
        }
    }

    private void ToggleMenu() => _menuOpen = !_menuOpen;

    private void CloseMenu()
    {
        if (_menuOpen) _menuOpen = false;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        if (_menuOpen)
        {
            _menuOpen = false;
            _ = InvokeAsync(StateHasChanged);
        }
    }

    private async Task ToggleThemeAsync()
    {
        await Theme.ToggleAsync();
        StateHasChanged();
    }

    private async Task LogoutAsync()
    {
        await Notifications.StopAsync();
        await Api.LogoutAsync();
        Nav.NavigateTo("");
    }

    public void Dispose()
    {
        Nav.LocationChanged -= OnLocationChanged;
        AuthProvider.AuthenticationStateChanged -= OnAuthChanged;
        Notifications.NotificationsChanged -= OnJobsMaybeChanged;
        Notifications.BookingChanged -= OnBookingChanged;
    }
}
