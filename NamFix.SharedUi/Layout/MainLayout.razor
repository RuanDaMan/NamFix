@inherits LayoutComponentBase
@implements IDisposable
@using Microsoft.Extensions.Logging
@inject ConnectivityService Connectivity
@inject ApiErrorNotifier Errors
@inject NavigationManager Nav
@inject ILogger<MainLayout> Logger

<div class="nf-app">
    <NavMenu />
    <main class="nf-main">
        <LoggingErrorBoundary @ref="_errorBoundary">
            <ChildContent>
                @Body
            </ChildContent>
            <ErrorContent>
                <div class="nf-error-card">
                    <h2>Something went wrong</h2>
                    <p>An unexpected error occurred on this page. The details have been logged. You can try again, or head back to search.</p>
                    <div class="nf-error-actions">
                        <button class="nf-cta" @onclick="Recover">Try again</button>
                        <a class="nf-link-btn" href="">Back to search</a>
                    </div>
                </div>
            </ErrorContent>
        </LoggingErrorBoundary>
    </main>
    <footer class="nf-footer">
        <span>NamFix — find trusted tradespeople across Namibia</span>
    </footer>
</div>

@* API error toasts — the short message for any failed request is shown here. *@
<div class="nf-toasts">
    @foreach (var toast in _toasts)
    {
        <div class="nf-toast" @key="toast.Id">
            <span class="nf-toast-msg">@toast.Message</span>
            <button class="nf-toast-x" @onclick="() => Dismiss(toast)" aria-label="Dismiss">✕</button>
        </div>
    }
</div>

@* Offline overlay — shown while the backend is unreachable, auto-clears the moment it returns. *@
@if (!Connectivity.IsOnline)
{
    <div class="nf-offline">
        <div class="nf-offline-card">
            <div class="nf-offline-spinner"></div>
            <h2>You're offline</h2>
            <p>We can't reach the NamFix server right now. You'll be reconnected automatically as soon as it's back.</p>
        </div>
    </div>
}

@code {
    private readonly List<Toast> _toasts = new();
    private LoggingErrorBoundary? _errorBoundary;

    protected override void OnInitialized()
    {
        Errors.ErrorReported += OnErrorReported;
        Connectivity.StateChanged += OnConnectivityChangedAsync;
        // Clear a caught error automatically when the user navigates away from the failed page.
        Nav.LocationChanged += OnLocationChanged;
        // Fire-and-forget: the connect/retry loop runs for the app's lifetime and never returns while
        // offline. Guarded so an unobserved fault can't surface as a browser "unhandledrejection"
        // (which would trip Blazor's error banner even though the app keeps running).
        _ = StartConnectivitySafeAsync();
    }

    private async Task StartConnectivitySafeAsync()
    {
        try
        {
            await Connectivity.StartAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Connectivity startup faulted unexpectedly.");
        }
    }

    private void Recover() => _errorBoundary?.Recover();

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e) => _errorBoundary?.Recover();

    private Task OnConnectivityChangedAsync() => InvokeAsync(StateHasChanged);

    private void OnErrorReported(string message)
    {
        var toast = new Toast(message);
        _toasts.Add(toast);
        _ = InvokeAsync(StateHasChanged);
        _ = AutoDismissAsync(toast);
    }

    private async Task AutoDismissAsync(Toast toast)
    {
        await Task.Delay(TimeSpan.FromSeconds(6));
        Dismiss(toast);
    }

    private void Dismiss(Toast toast)
    {
        if (_toasts.Remove(toast))
            _ = InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Errors.ErrorReported -= OnErrorReported;
        Connectivity.StateChanged -= OnConnectivityChangedAsync;
        Nav.LocationChanged -= OnLocationChanged;
    }

    private sealed record Toast(string Message)
    {
        public Guid Id { get; } = Guid.NewGuid();
    }
}
