@page "/bookings/{Id:guid}"
@attribute [Authorize]
@implements IDisposable
@inject NamFixApiClient Api
@inject NotificationService Notifications
@inject IGeolocationService Geo
@inject IJSRuntime JS

<PageTitle>Booking — NamFix</PageTitle>

@if (_loading)
{
    <p class="nf-muted">Loading…</p>
}
else if (_booking is null)
{
    <p class="nf-muted">Booking not found.</p>
}
else
{
    <div class="nf-booking">
        <div class="nf-profile-head">
            <div>
                <h1>@(IsProvider ? _booking.ClientName : (_booking.ProviderBusinessName ?? "Your job request"))</h1>
                <p class="nf-muted">@_booking.ServiceDescription</p>
            </div>
            <span class="nf-badge @StatusClass(_booking.Status)">@StatusLabel(_booking.Status)</span>
        </div>

        @* ---- Quotes: client reviews provider responses and picks one ---- *@
        @if (IsClient && _booking.Status is JobStatus.Requested or JobStatus.Quoted)
        {
            <section class="nf-booking-section">
                <h3>Quotes (@_responses.Count)</h3>
                @if (_responses.Count == 0)
                {
                    <p class="nf-muted">No responses yet. Providers are being notified — check back shortly.</p>
                }
                else
                {
                    <div class="nf-booking-list">
                        @foreach (var r in _responses)
                        {
                            <div class="nf-booking-row" @key="r.Id">
                                <div class="nf-booking-row-main">
                                    <strong>@r.ProviderBusinessName</strong>
                                    <span class="nf-muted">
                                        @if (r.ProviderRatingAverage is { } avg)
                                        {
                                            <span>★ @avg.ToString("0.0") (@r.ProviderRatingCount)</span>
                                        }
                                        @if (r.ProviderAvgResponseMinutes is { } mins)
                                        {
                                            <span> · replies ~@mins min</span>
                                        }
                                    </span>
                                    @if (!string.IsNullOrWhiteSpace(r.QuoteNote))
                                    {
                                        <span class="nf-muted">@r.QuoteNote</span>
                                    }
                                    @if (r.ProposedStartUtc is { } slot)
                                    {
                                        <span class="nf-muted">Suggested: @Local(slot)</span>
                                    }
                                </div>
                                <div class="nf-booking-row-side">
                                    <strong>@(r.QuoteAmount is { } q ? $"NAD {q:0.00}" : "Interested")</strong>
                                    <button class="nf-cta" @onclick="() => AcceptQuoteAsync(r.Id)">Accept</button>
                                </div>
                            </div>
                        }
                    </div>
                }
                <div class="nf-booking-actions">
                    <button class="nf-link-btn" @onclick="CancelAsync">Cancel this request</button>
                </div>
            </section>
        }

        @* Schedule/delivery/chat only apply once a provider is chosen (not a broadcast still gathering quotes). *@
        @if (ShowJobDetails)
        {
        @* ---- Scheduling: the back-and-forth time negotiation ---- *@
        <section class="nf-booking-section">
            <h3>Schedule</h3>
            @if (_booking.Status == JobStatus.Scheduled)
            {
                <p class="nf-success">Confirmed for @Local(_booking.ConfirmedStartUtc).</p>
            }
            else if (_booking.ProposedStartUtc is not null)
            {
                <p>
                    Proposed time: <strong>@Local(_booking.ProposedStartUtc)</strong>
                    <span class="nf-muted">(@(_booking.ProposedByUserId == _userId ? "by you" : "by the other party"))</span>
                </p>
            }

            @if (MyTurnToApprove)
            {
                <p class="nf-muted">It's your turn to respond to the proposed time.</p>
                <div class="nf-booking-actions">
                    <button class="nf-cta" @onclick="AcceptAsync">✓ Accept @Local(_booking.ProposedStartUtc)</button>
                </div>
            }
            else if (WaitingOnOther)
            {
                <p class="nf-muted">Waiting for the other party to respond to your proposed time.</p>
            }

            @if (CanNegotiate)
            {
                <div class="nf-booking-propose">
                    <label>@(_booking.Status == JobStatus.Scheduled ? "Reschedule to" : "Propose a different time")</label>
                    <div class="nf-pay-row">
                        <input type="datetime-local" @bind="_proposeTime" />
                        <button class="nf-link-btn" @onclick="ProposeAsync">Propose</button>
                    </div>
                </div>
            }

            @if (IsProvider && _booking.Status == JobStatus.Scheduled)
            {
                <div class="nf-booking-actions">
                    <button class="nf-cta" @onclick="StartAsync">▶ Start job</button>
                </div>
            }

            <div class="nf-booking-actions">
                @if (IsProvider && (_booking.Status is JobStatus.PendingProvider or JobStatus.PendingClient))
                {
                    <button class="nf-link-btn" @onclick="DeclineAsync">Decline request</button>
                }
                @if (CanCancel)
                {
                    <button class="nf-link-btn" @onclick="CancelAsync">Cancel booking</button>
                }
                @if (CanFlagNoShow)
                {
                    <button class="nf-link-btn" @onclick="NoShowAsync">Report no-show</button>
                }
            </div>
        </section>

        @* ---- Location: the client pins the job spot on the map; it's shared automatically. ---- *@
        <section class="nf-booking-section">
            <h3>Location</h3>
            @if (!string.IsNullOrWhiteSpace(_booking.LocationText))
            {
                <p>📍 @_booking.LocationText</p>
            }
            else
            {
                <p class="nf-muted">No location shared yet.</p>
            }

            @if (IsClient && IsActive)
            {
                <div class="nf-booking-propose">
                    <p class="nf-muted">Tap the map to drop a pin — your location is shared with the tradesperson automatically.</p>
                    <div class="nf-booking-actions">
                        <button class="nf-link-btn" @onclick="UseMyLocationAsync" disabled="@(_locating || _sharing)">
                            @if (_locating)
                            {
                                <span class="nf-inline-spinner"></span> <span>Locating…</span>
                            }
                            else
                            {
                                <span>📍 Use my current location</span>
                            }
                        </button>
                        @if (_sharing)
                        {
                            <span class="nf-loading"><span class="nf-inline-spinner"></span> Sharing…</span>
                        }
                        else if (_locShared)
                        {
                            <span class="nf-success">Shared ✓</span>
                        }
                    </div>
                    <input placeholder="Address or directions (optional)" @bind="_locationText" @bind:after="ShareLocationSoon" />
                    <MapView PinMode="true" OnPinned="OnMapPinned"
                             Center="PinCenter" Zoom="14" Height="260px"
                             Markers="PinMarkers" />
                </div>
            }
            else if (_booking.LocationLat is not null && _booking.LocationLng is not null)
            {
                <button class="nf-link-btn" @onclick="() => _showMap = !_showMap">
                    @(_showMap ? "Hide map" : "🗺️ Show map")
                </button>
                @if (_showMap)
                {
                    <MapView Center="new GeoPoint(_booking.LocationLat.Value, _booking.LocationLng.Value)"
                             Zoom="15" Height="220px"
                             Markers="new[]{ new MapMarker(new GeoPoint(_booking.LocationLat.Value, _booking.LocationLng.Value), _booking.LocationText!) }" />
                }
            }
        </section>

        @* ---- Invoice & completion ---- *@
        <section class="nf-booking-section">
            <h3>Job &amp; invoice</h3>

            @if (_booking.InvoiceAmount is { } amount)
            {
                <p><strong>Amount: @_booking.Currency @amount.ToString("0.00")</strong></p>
                @if (!string.IsNullOrWhiteSpace(_booking.InvoiceNotes))
                {
                    <p class="nf-muted">@_booking.InvoiceNotes</p>
                }
            }

            @if (_booking.HasInvoiceFile)
            {
                <button class="nf-link-btn" @onclick="DownloadInvoiceAsync">🧾 Download invoice file</button>
            }

            @if (IsProvider && _booking.Status is JobStatus.Scheduled or JobStatus.InProgress)
            {
                <div class="nf-booking-propose">
                    <label>Mark done &amp; charge</label>
                    <div class="nf-pay-row">
                        <input type="number" min="0.01" step="0.01" placeholder="Amount (NAD)" @bind="_invoiceAmount" />
                        <input placeholder="Invoice notes (optional)" @bind="_invoiceNotes" />
                    </div>
                    <div class="nf-booking-actions">
                        <label class="nf-link-btn">
                            📎 @(_invoiceFileName ?? "Attach invoice file")
                            <InputFile OnChange="OnInvoiceSelected" style="display:none" />
                        </label>
                        <button class="nf-cta" @onclick="CompleteAsync" disabled="@(_invoiceAmount <= 0)">Mark complete</button>
                    </div>
                </div>
            }
            else if (IsProvider && _booking.Status == JobStatus.Completed && !_booking.HasInvoiceFile)
            {
                <label class="nf-link-btn">
                    📎 @(_invoiceFileName ?? "Upload invoice file")
                    <InputFile OnChange="OnInvoiceSelected" style="display:none" />
                </label>
            }

            @if (IsClient && _booking.Status == JobStatus.Completed)
            {
                <div class="nf-pay">
                    <p class="nf-muted">Pay the amount the provider invoiced. You can't pay a custom amount.</p>
                    <button class="nf-cta" @onclick="PayAsync" disabled="@(_booking.InvoiceAmount is null or <= 0)">
                        Pay @_booking.Currency @(_booking.InvoiceAmount?.ToString("0.00"))
                    </button>
                </div>
            }
            else if (_booking.Status is JobStatus.Paid or JobStatus.Reviewed)
            {
                <p class="nf-success">Paid through NamFix.</p>
            }

            @if (IsClient && _booking.Status == JobStatus.Paid)
            {
                <div class="nf-booking-propose">
                    <label>Rate the provider</label>
                    <div class="nf-pay-row">
                        <select @bind="_reviewRating">
                            <option value="5">★★★★★ Excellent</option>
                            <option value="4">★★★★ Good</option>
                            <option value="3">★★★ Okay</option>
                            <option value="2">★★ Poor</option>
                            <option value="1">★ Bad</option>
                        </select>
                        <input placeholder="Comment (optional)" @bind="_reviewComment" />
                    </div>
                    <div class="nf-booking-actions">
                        <button class="nf-cta" @onclick="ReviewAsync">Submit review</button>
                    </div>
                </div>
            }

            @* The left review is visible to both parties — the tradesperson sees the client's rating & message. *@
            @if (_booking.ReviewRating is { } reviewRating)
            {
                <div class="nf-booking-review">
                    <h4>@(IsProvider ? $"Review from {_booking.ClientName}" : "Your review")</h4>
                    <RatingStars Value="reviewRating" Count="0" />
                    @if (!string.IsNullOrWhiteSpace(_booking.ReviewComment))
                    {
                        <p class="nf-review-comment">“@_booking.ReviewComment”</p>
                    }
                </div>
            }
        </section>

        @* ---- Chat ---- *@
        <section class="nf-booking-section">
            <h3>Messages</h3>
            <div class="nf-chat">
                @foreach (var m in _messages)
                {
                    <div class="nf-chat-msg @(m.SenderUserId == _userId ? "mine" : "")" @key="m.Id">
                        <span class="nf-chat-meta">@(m.SenderUserId == _userId ? "You" : m.SenderName) · @m.CreatedAtUtc.ToLocalTime().ToString("g")</span>
                        <span class="nf-chat-body">@m.Body</span>
                    </div>
                }
                @if (_messages.Count == 0)
                {
                    <p class="nf-muted">No messages yet. Say hello 👋</p>
                }
            </div>
            <div class="nf-pay-row nf-chat-input">
                <input placeholder="Type a message…" @bind="_draft" @bind:event="oninput" @onkeydown="OnChatKeyDown" />
                <button class="nf-cta" @onclick="SendMessageAsync" disabled="@string.IsNullOrWhiteSpace(_draft)">Send</button>
            </div>
        </section>
        }
    </div>
}

@code {
    [Parameter] public Guid Id { get; set; }
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private JobRequestDto? _booking;
    private List<JobMessageDto> _messages = new();
    private List<JobResponseDto> _responses = new();
    private bool _loading = true;
    private Guid _userId;

    private DateTime _proposeTime = DateTime.Now.Date.AddDays(1).AddHours(9);
    private string? _locationText;
    private double? _locLat;
    private double? _locLng;
    private bool _locating;
    private bool _sharing;
    private bool _locShared;
    private CancellationTokenSource? _shareCts;
    private bool _showMap;
    private GeoPoint? _mapCenter;
    private decimal _invoiceAmount;
    private string? _invoiceNotes;
    private string? _invoiceFileName;
    private string _draft = string.Empty;
    private int _reviewRating = 5;
    private string? _reviewComment;

    private bool IsProvider => _booking is not null && _booking.ProviderUserId == _userId;
    private bool IsClient => _booking is not null && _booking.ClientUserId == _userId;
    private bool IsActive => _booking is not null &&
        _booking.Status is not (JobStatus.Paid or JobStatus.Reviewed or JobStatus.Cancelled
            or JobStatus.Declined or JobStatus.NoShow);
    private bool CanFlagNoShow => _booking is not null &&
        _booking.Status is JobStatus.Scheduled or JobStatus.InProgress &&
        _booking.ConfirmedStartUtc is { } start && DateTime.UtcNow >= start;
    private bool ShowJobDetails => _booking is not null &&
        _booking.Status is not (JobStatus.Requested or JobStatus.Quoted);
    private bool MyTurnToApprove => _booking is not null &&
        ((_booking.Status == JobStatus.PendingProvider && IsProvider) ||
         (_booking.Status == JobStatus.PendingClient && IsClient));
    private bool WaitingOnOther => _booking is not null &&
        ((_booking.Status == JobStatus.PendingProvider && IsClient) ||
         (_booking.Status == JobStatus.PendingClient && IsProvider));
    private bool CanNegotiate => _booking is not null &&
        _booking.Status is JobStatus.PendingProvider or JobStatus.PendingClient or JobStatus.Scheduled;
    private bool CanCancel => _booking is not null &&
        _booking.Status is JobStatus.PendingProvider or JobStatus.PendingClient or JobStatus.Scheduled;

    protected override async Task OnInitializedAsync()
    {
        _userId = await CurrentUserId();
        Notifications.BookingChanged += OnBookingChanged;
        Notifications.MessagePosted += OnMessagePosted;
    }

    protected override async Task OnParametersSetAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        _booking = await Api.GetBookingAsync(Id);
        _messages = _booking is null || !ShowJobDetails ? new() : await Api.GetBookingMessagesAsync(Id);
        // The client sees quotes while the job is still gathering them.
        _responses = _booking is not null && IsClient && !ShowJobDetails
            ? await Api.GetJobResponsesAsync(Id)
            : new();
        _loading = false;
        StateHasChanged();
    }

    private void OnBookingChanged(Guid bookingId)
    {
        if (bookingId == Id) _ = InvokeAsync(LoadAsync);
    }

    private void OnMessagePosted(Guid bookingId, JobMessageDto message)
    {
        if (bookingId != Id) return;
        _ = InvokeAsync(() =>
        {
            if (_messages.All(m => m.Id != message.Id))
            {
                _messages.Add(message);
                StateHasChanged();
            }
        });
    }

    private void Apply(JobRequestDto? updated)
    {
        if (updated is not null) _booking = updated;
    }

    private async Task AcceptAsync() => Apply(await Api.AcceptBookingAsync(Id));
    private async Task DeclineAsync() => Apply(await Api.DeclineBookingAsync(Id));
    private async Task CancelAsync() => Apply(await Api.CancelBookingAsync(Id));
    private async Task StartAsync() => Apply(await Api.StartBookingAsync(Id));
    private async Task NoShowAsync() => Apply(await Api.FlagNoShowAsync(Id));

    private async Task ReviewAsync() =>
        Apply(await Api.ReviewBookingAsync(Id, new CreateJobReviewRequest
        {
            Rating = _reviewRating,
            Comment = _reviewComment
        }));

    private async Task ProposeAsync()
    {
        var utc = DateTime.SpecifyKind(_proposeTime, DateTimeKind.Local).ToUniversalTime();
        Apply(await Api.ProposeBookingTimeAsync(Id, utc));
    }

    private async Task UseMyLocationAsync()
    {
        _locating = true;
        try
        {
            var point = await Geo.GetCurrentLocationAsync();
            if (point is { } p)
            {
                ApplyPin(p);
                _mapCenter = p;         // pan the map to the located point
                await ShareNowAsync();  // an explicit action shares immediately
            }
        }
        finally
        {
            _locating = false;
        }
    }

    // A tap on the map moves the pin but doesn't recenter — the tapped point is already on-screen.
    // This arrives via a JS-interop callback (off the render dispatcher), so marshal the re-render
    // back onto it with InvokeAsync — a bare StateHasChanged() here wouldn't refresh the UI.
    private async Task OnMapPinned(GeoPoint p)
    {
        ApplyPin(p);
        await InvokeAsync(StateHasChanged);
        ScheduleShare();  // debounced so rapid taps while positioning collapse into one share
    }

    private void ApplyPin(GeoPoint p)
    {
        _locLat = p.Latitude;
        _locLng = p.Longitude;
    }

    /// <summary>Re-share after the (optional) address text is edited, once a pin exists.</summary>
    private void ShareLocationSoon() => ScheduleShare();

    /// <summary>Debounce an auto-share; the last pin/edit within the window wins.</summary>
    private void ScheduleShare()
    {
        if (_locLat is null) return;
        _shareCts?.Cancel();
        var cts = new CancellationTokenSource();
        _shareCts = cts;
        _ = ShareAfterDelayAsync(cts.Token);
    }

    private async Task ShareAfterDelayAsync(CancellationToken ct)
    {
        try { await Task.Delay(700, ct); }
        catch (TaskCanceledException) { return; }
        if (!ct.IsCancellationRequested)
            await InvokeAsync(ShareNowAsync);
    }

    private async Task ShareNowAsync()
    {
        if (_locLat is null || _locLng is null || _sharing) return;
        _sharing = true;
        _locShared = false;
        StateHasChanged();
        try
        {
            _locShared = await SaveLocationAsync();
        }
        finally
        {
            _sharing = false;
            StateHasChanged();
        }
    }

    /// <summary>Stable center: located point → already-shared location → Windhoek. Not tied to each tap.</summary>
    private GeoPoint PinCenter =>
        _mapCenter
        ?? (_booking?.LocationLat is { } blat && _booking.LocationLng is { } blng
            ? new GeoPoint(blat, blng)
            : new GeoPoint(-22.56, 17.08));

    /// <summary>The single pin marker, driven by state (current pick, else the already-shared location).</summary>
    private MapMarker[] PinMarkers =>
        _locLat is { } lat && _locLng is { } lng
            ? new[] { new MapMarker(new GeoPoint(lat, lng), "Job location") }
            : _booking?.LocationLat is { } blat && _booking.LocationLng is { } blng
                ? new[] { new MapMarker(new GeoPoint(blat, blng), "Job location") }
                : Array.Empty<MapMarker>();

    private async Task<bool> SaveLocationAsync()
    {
        if (_locLat is null || _locLng is null) return false;
        // The client sees no raw coordinates — send a readable label (typed directions, else a
        // friendly default) and let the map pin carry the exact spot.
        var text = string.IsNullOrWhiteSpace(_locationText) ? "Pinned on map" : _locationText!.Trim();
        var updated = await Api.SetBookingLocationAsync(Id, new SetJobLocationRequest
        {
            LocationText = text,
            Lat = _locLat,
            Lng = _locLng
        });
        Apply(updated);
        return updated is not null;
    }

    private async Task CompleteAsync()
    {
        if (_invoiceAmount <= 0) return;
        Apply(await Api.CompleteBookingAsync(Id, new CompleteJobRequest
        {
            InvoiceAmount = _invoiceAmount,
            InvoiceNotes = _invoiceNotes
        }));
    }

    private async Task OnInvoiceSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        _invoiceFileName = file.Name;
        using var stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
        using var ms = new MemoryStream();
        await stream.CopyToAsync(ms);
        ms.Position = 0;
        if (await Api.UploadBookingInvoiceAsync(Id, ms, file.Name, file.ContentType))
            await LoadAsync();
    }

    private async Task DownloadInvoiceAsync()
    {
        var dl = await Api.DownloadBookingInvoiceAsync(Id);
        if (dl is not null)
            await JS.InvokeVoidAsync("namfix.downloadFile", dl.FileName, dl.ContentType, Convert.ToBase64String(dl.Content));
    }

    private async Task PayAsync() => Apply(await Api.PayBookingAsync(Id));

    private async Task AcceptQuoteAsync(Guid responseId)
    {
        var updated = await Api.AcceptQuoteAsync(Id, responseId);
        if (updated is not null)
        {
            _booking = updated;
            await LoadAsync();
        }
    }

    private async Task OnChatKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SendMessageAsync();
    }

    private async Task SendMessageAsync()
    {
        var body = _draft.Trim();
        if (body.Length == 0) return;
        _draft = string.Empty;
        var sent = await Api.SendBookingMessageAsync(Id, body);
        if (sent is not null && _messages.All(m => m.Id != sent.Id))
            _messages.Add(sent);
    }

    private async Task<Guid> CurrentUserId()
    {
        if (AuthState is null) return Guid.Empty;
        var user = (await AuthState).User;
        return Guid.TryParse(user.FindFirst(ClaimTypes.NameIdentifier)?.Value, out var id) ? id : Guid.Empty;
    }

    private static string Local(DateTime? utc) =>
        utc is { } d ? d.ToLocalTime().ToString("ddd d MMM yyyy, HH:mm") : "—";

    private static string StatusLabel(JobStatus s) => s switch
    {
        JobStatus.Requested => "Gathering quotes",
        JobStatus.Quoted => "Quotes received",
        JobStatus.PendingProvider => "Awaiting provider",
        JobStatus.PendingClient => "Awaiting client",
        JobStatus.Scheduled => "Scheduled",
        JobStatus.InProgress => "In progress",
        JobStatus.Completed => "Awaiting payment",
        JobStatus.Paid => "Paid",
        JobStatus.Reviewed => "Reviewed",
        JobStatus.Cancelled => "Cancelled",
        JobStatus.Declined => "Declined",
        JobStatus.NoShow => "No-show",
        _ => s.ToString()
    };

    private static string StatusClass(JobStatus s) => s switch
    {
        JobStatus.Scheduled or JobStatus.InProgress or JobStatus.Paid or JobStatus.Reviewed => "avail-available",
        JobStatus.Completed => "emergency",
        JobStatus.Cancelled or JobStatus.Declined or JobStatus.NoShow => "avail-busy",
        _ => "verified"
    };

    public void Dispose()
    {
        Notifications.BookingChanged -= OnBookingChanged;
        Notifications.MessagePosted -= OnMessagePosted;
        _shareCts?.Cancel();
        _shareCts?.Dispose();
    }
}
