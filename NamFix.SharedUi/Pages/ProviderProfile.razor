@page "/provider/{Id:guid}"
@inject NamFixApiClient Api
@inject NavigationManager Nav

<PageTitle>@(_provider?.BusinessName ?? "Provider") — NamFix</PageTitle>

@if (_loading)
{
    <p class="nf-muted">Loading…</p>
}
else if (_provider is null)
{
    <p class="nf-muted">Provider not found.</p>
}
else
{
    <div class="nf-profile">
        <div class="nf-profile-head">
            <div>
                <h1>@_provider.BusinessName
                    @if (_provider.IsVerified)
                    {
                        <span class="nf-badge verified">✓ Verified</span>
                    }
                </h1>
                <p class="nf-muted">@_provider.PrimaryCategoryName · 📍 @_provider.PrimaryTownName</p>
                <p class="nf-muted">
                    @if (_provider.YearsExperience is { } yrs)
                    {
                        <span class="nf-badge">@yrs yrs experience</span>
                    }
                    @if (_provider.AvgResponseMinutes is { } mins)
                    {
                        <span class="nf-badge">⚡ replies ~@mins min</span>
                    }
                    @if (_provider.StartingPrice is { } price)
                    {
                        <span class="nf-badge">from N$@price.ToString("0")</span>
                    }
                </p>
                <RatingStars Value="_provider.RatingAverage" Count="_provider.RatingCount" />
            </div>
            <div class="nf-profile-actions">
                @if (!string.IsNullOrWhiteSpace(_provider.OwnerPhoneNumber))
                {
                    <a class="nf-cta whatsapp" href="@WhatsAppLink" target="_blank" rel="noopener">💬 Chat on WhatsApp</a>
                    <a class="nf-link-btn" href="tel:@_provider.OwnerPhoneNumber">📞 Call</a>
                }
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(_provider.Description))
        {
            <p class="nf-desc">@_provider.Description</p>
        }

        <div class="nf-tags">
            @foreach (var tag in _provider.Tags)
            {
                <span class="nf-tag">@tag</span>
            }
        </div>

        @if (_provider.RateCards.Count > 0)
        {
            <section class="nf-booking-section">
                <h3>Rate card</h3>
                <div class="nf-booking-list">
                    @foreach (var rc in _provider.RateCards)
                    {
                        <div class="nf-booking-row" @key="rc.Id">
                            <div class="nf-booking-row-main">
                                <strong>@rc.Title</strong>
                                <span class="nf-muted">@rc.Description</span>
                            </div>
                            <div class="nf-booking-row-side">
                                <strong>N$@rc.Price.ToString("0.00") / @RateUnitLabel(rc.Unit)</strong>
                            </div>
                        </div>
                    }
                </div>
                <p class="nf-muted">Indicative prices — confirm the final amount in your booking.</p>
            </section>
        }

        @if (_provider.Latitude is not null && _provider.Longitude is not null)
        {
            <MapView Center="new GeoPoint(_provider.Latitude.Value, _provider.Longitude.Value)"
                     Zoom="14" Height="280px"
                     Markers="new[]{ new MapMarker(new GeoPoint(_provider.Latitude.Value, _provider.Longitude.Value), _provider.BusinessName) }" />
        }

        <AuthorizeView Roles="Client">
            <section class="nf-pay">
                <h3>Request a booking</h3>
                <p class="nf-muted">Request a time, agree the details, and pay securely once the job is done —
                    payments always go through a booking, never a random amount.</p>
                <div class="nf-booking-propose">
                    <label>What do you need done?</label>
                    <input placeholder="e.g. Fix a leaking kitchen tap" @bind="_bookingDescription" @bind:event="oninput" />
                    <label>Preferred time</label>
                    <div class="nf-pay-row">
                        <input type="datetime-local" @bind="_bookingTime" />
                        <button class="nf-cta" @onclick="RequestBookingAsync"
                                disabled="@(string.IsNullOrWhiteSpace(_bookingDescription) || _submitting)">
                            Request booking
                        </button>
                    </div>
                </div>
            </section>
        </AuthorizeView>

        <section class="nf-reviews">
            <h3>Reviews (@_reviews.Count)</h3>

            <AuthorizeView Roles="Client">
                <div class="nf-review-form">
                    <select @bind="_newReview.Rating">
                        @for (var i = 5; i >= 1; i--)
                        {
                            <option value="@i">@i ★</option>
                        }
                    </select>
                    <input placeholder="Share your experience" @bind="_newReview.Comment" />
                    <button class="nf-link-btn" @onclick="SubmitReviewAsync">Post</button>
                </div>
            </AuthorizeView>

            @foreach (var r in _reviews)
            {
                <div class="nf-review">
                    <div class="nf-review-head">
                        <strong>@r.ClientName</strong>
                        <RatingStars Value="r.Rating" Count="0" />
                        @if (r.IsVerified)
                        {
                            <span class="nf-badge verified">Verified</span>
                        }
                    </div>
                    <p>@r.Comment</p>
                </div>
            }
            @if (_reviews.Count == 0)
            {
                <p class="nf-muted">No reviews yet.</p>
            }
        </section>
    </div>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private ProviderDto? _provider;
    private List<ReviewDto> _reviews = new();
    private bool _loading = true;
    private string? _bookingDescription;
    private DateTime _bookingTime = DateTime.Now.Date.AddDays(1).AddHours(9);
    private bool _submitting;
    private CreateReviewRequest _newReview = new() { Rating = 5 };

    protected override async Task OnParametersSetAsync()
    {
        _loading = true;
        _provider = await Api.GetProviderAsync(Id);
        _reviews = await Api.GetReviewsAsync(Id);
        _newReview = new CreateReviewRequest { ProviderId = Id, Rating = 5 };
        _loading = false;
    }

    private string WhatsAppLink
    {
        get
        {
            var phone = new string((_provider?.OwnerPhoneNumber ?? "").Where(char.IsDigit).ToArray());
            var msg = Uri.EscapeDataString($"Hi {_provider?.BusinessName}, I found you on NamFix and would like a quote.");
            return $"https://wa.me/{phone}?text={msg}";
        }
    }

    private async Task RequestBookingAsync()
    {
        if (string.IsNullOrWhiteSpace(_bookingDescription)) return;
        _submitting = true;
        var booking = await Api.CreateBookingAsync(new CreateDirectBookingRequest
        {
            ProviderId = Id,
            ServiceDescription = _bookingDescription!,
            RequestedStartUtc = DateTime.SpecifyKind(_bookingTime, DateTimeKind.Local).ToUniversalTime()
        });
        _submitting = false;
        if (booking is not null) Nav.NavigateTo($"bookings/{booking.Id}");
    }

    private static string RateUnitLabel(RateUnit u) => u switch
    {
        RateUnit.PerJob => "job",
        RateUnit.PerHour => "hour",
        RateUnit.Callout => "callout",
        RateUnit.PerUnit => "unit",
        _ => u.ToString()
    };

    private async Task SubmitReviewAsync()
    {
        if (await Api.AddReviewAsync(_newReview))
        {
            _reviews = await Api.GetReviewsAsync(Id);
            _provider = await Api.GetProviderAsync(Id);
            _newReview = new CreateReviewRequest { ProviderId = Id, Rating = 5 };
        }
    }
}
