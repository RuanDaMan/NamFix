@page "/forgot-password"
@inject NamFixApiClient Api

<PageTitle>Forgot password — NamFix</PageTitle>

<div class="nf-form-card">
    <h2>Forgot your password?</h2>
    @if (_sent)
    {
        <p>If an account exists for <strong>@_model.Email</strong>, we've sent a password reset link.
           Check your inbox and follow the link to choose a new password.</p>
        <p class="nf-muted"><a href="login">Back to log in</a></p>
    }
    else
    {
        <p class="nf-muted">Enter your email and we'll send you a link to reset your password.</p>
        <EditForm Model="_model" OnValidSubmit="SubmitAsync">
            <DataAnnotationsValidator />
            <label>Email</label>
            <InputText @bind-Value="_model.Email" type="email" />
            <button class="nf-cta" type="submit" disabled="@_busy">@(_busy ? "…" : "Send reset link")</button>
        </EditForm>
        <p class="nf-muted"><a href="login">Back to log in</a></p>
    }
</div>

@code {
    private readonly ForgotPasswordRequest _model = new();
    private bool _busy;
    private bool _sent;

    private async Task SubmitAsync()
    {
        _busy = true;
        // Always show the same confirmation regardless of whether the account exists.
        await Api.ForgotPasswordAsync(_model);
        _busy = false;
        _sent = true;
    }
}
