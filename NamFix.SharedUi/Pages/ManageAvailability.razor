@page "/provider/availability"
@attribute [Authorize(Roles = "ServiceProvider")]
@inject NamFixApiClient Api

<PageTitle>Availability — NamFix</PageTitle>

<h1>Availability</h1>
<p class="nf-muted">Set the hours you normally work and block out dates you're away. Confirmed bookings automatically fill your calendar.</p>

@if (_loading)
{
    <p class="nf-muted">Loading…</p>
}
else
{
    <section class="nf-booking-section">
        <h3>Weekly hours</h3>
        @foreach (var row in _rules)
        {
            <div class="nf-pay-row" @key="row.Key">
                <select @bind="row.Day">
                    @for (var d = 0; d < 7; d++)
                    {
                        var day = d;
                        <option value="@day">@DayName(day)</option>
                    }
                </select>
                <input type="time" @bind="row.Start" />
                <span>to</span>
                <input type="time" @bind="row.End" />
                <button class="nf-link-btn" @onclick="() => _rules.Remove(row)">✕</button>
            </div>
        }
        <div class="nf-booking-actions">
            <button class="nf-link-btn" @onclick="AddRow">+ Add window</button>
            <button class="nf-cta" @onclick="SaveRulesAsync">Save hours</button>
            @if (_savedRules)
            {
                <span class="nf-success">Saved ✓</span>
            }
        </div>
    </section>

    <section class="nf-booking-section">
        <h3>Time off</h3>
        @foreach (var t in _timeOff)
        {
            <div class="nf-booking-row" @key="t.Id">
                <div class="nf-booking-row-main">
                    <strong>@t.StartUtc.ToLocalTime().ToString("d MMM") – @t.EndUtc.ToLocalTime().ToString("d MMM")</strong>
                    <span class="nf-muted">@t.Reason</span>
                </div>
                <div class="nf-booking-row-side">
                    <button class="nf-link-btn" @onclick="() => RemoveTimeOffAsync(t.Id)">Remove</button>
                </div>
            </div>
        }
        <div class="nf-pay-row">
            <input type="date" @bind="_offStart" />
            <span>to</span>
            <input type="date" @bind="_offEnd" />
            <input placeholder="Reason (optional)" @bind="_offReason" />
            <button class="nf-cta" @onclick="AddTimeOffAsync">Add</button>
        </div>
    </section>

    @if (_bookedSlots.Count > 0)
    {
        <section class="nf-booking-section">
            <h3>Booked slots</h3>
            <ul class="nf-muted">
                @foreach (var s in _bookedSlots)
                {
                    <li>@s.StartUtc.ToLocalTime().ToString("ddd d MMM, HH:mm")</li>
                }
            </ul>
        </section>
    }
}

@code {
    private sealed class RuleRow
    {
        public Guid Key { get; } = Guid.NewGuid();
        public int Day { get; set; }
        public TimeOnly Start { get; set; } = new(8, 0);
        public TimeOnly End { get; set; } = new(17, 0);
    }

    private Guid _providerId;
    private readonly List<RuleRow> _rules = new();
    private List<TimeOffDto> _timeOff = new();
    private List<BookedSlotDto> _bookedSlots = new();
    private DateTime _offStart = DateTime.Today;
    private DateTime _offEnd = DateTime.Today.AddDays(1);
    private string? _offReason;
    private bool _loading = true;
    private bool _savedRules;

    protected override async Task OnInitializedAsync()
    {
        var me = await Api.GetMyProviderAsync();
        if (me is not null)
        {
            _providerId = me.Id;
            await LoadAsync();
        }
        _loading = false;
    }

    private async Task LoadAsync()
    {
        var availability = await Api.GetProviderAvailabilityAsync(_providerId);
        _rules.Clear();
        if (availability is not null)
        {
            foreach (var r in availability.Rules)
                _rules.Add(new RuleRow { Day = r.DayOfWeek, Start = TimeOnly.FromTimeSpan(r.StartTime), End = TimeOnly.FromTimeSpan(r.EndTime) });
            _timeOff = availability.TimeOff;
            _bookedSlots = availability.BookedSlots;
        }
    }

    private void AddRow() => _rules.Add(new RuleRow());

    private async Task SaveRulesAsync()
    {
        _savedRules = false;
        var request = new SaveAvailabilityRequest
        {
            Rules = _rules
                .Where(r => r.End > r.Start)
                .Select(r => new AvailabilityRuleDto
                {
                    DayOfWeek = r.Day,
                    StartTime = r.Start.ToTimeSpan(),
                    EndTime = r.End.ToTimeSpan()
                }).ToList()
        };
        if (await Api.SaveAvailabilityAsync(request)) _savedRules = true;
    }

    private async Task AddTimeOffAsync()
    {
        var added = await Api.AddTimeOffAsync(new AddTimeOffRequest
        {
            StartUtc = DateTime.SpecifyKind(_offStart, DateTimeKind.Local).ToUniversalTime(),
            EndUtc = DateTime.SpecifyKind(_offEnd, DateTimeKind.Local).ToUniversalTime(),
            Reason = _offReason
        });
        if (added is not null) { _offReason = null; await LoadAsync(); }
    }

    private async Task RemoveTimeOffAsync(Guid id)
    {
        if (await Api.RemoveTimeOffAsync(id)) await LoadAsync();
    }

    private static string DayName(int d) => d switch
    {
        0 => "Sunday", 1 => "Monday", 2 => "Tuesday", 3 => "Wednesday",
        4 => "Thursday", 5 => "Friday", 6 => "Saturday", _ => d.ToString()
    };
}
