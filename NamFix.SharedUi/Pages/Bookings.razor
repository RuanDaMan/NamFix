@page "/bookings"
@attribute [Authorize]
@implements IDisposable
@inject NamFixApiClient Api
@inject NotificationService Notifications
@inject NavigationManager Nav

<PageTitle>My bookings — NamFix</PageTitle>

<h1>My bookings</h1>

@if (_loading)
{
    <p class="nf-muted">Loading…</p>
}
else if (_bookings.Count == 0)
{
    <p class="nf-muted">No bookings yet. Find a provider and request a booking to get started.</p>
    <a class="nf-cta" href="">Find a provider</a>
}
else
{
    <div class="nf-booking-list">
        @foreach (var b in _bookings)
        {
            <a class="nf-booking-row" href="bookings/@b.Id" @key="b.Id">
                <div class="nf-booking-row-main">
                    <strong>@Counterpart(b)</strong>
                    <span class="nf-muted">@b.ServiceDescription</span>
                    @if (b.ReviewRating is { } rating)
                    {
                        <span class="nf-booking-review-line">
                            <RatingStars Value="rating" Count="0" />
                            @if (!string.IsNullOrWhiteSpace(b.ReviewComment))
                            {
                                <span class="nf-muted">“@b.ReviewComment”</span>
                            }
                        </span>
                    }
                </div>
                <div class="nf-booking-row-side">
                    <span class="nf-badge @StatusClass(b.Status)">@StatusLabel(b.Status)</span>
                    <span class="nf-muted nf-booking-time">@WhenLabel(b)</span>
                </div>
            </a>
        }
    </div>
}

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private List<JobRequestDto> _bookings = new();
    private bool _loading = true;
    private Guid _userId;

    protected override async Task OnInitializedAsync()
    {
        _userId = await CurrentUserId();
        Notifications.BookingChanged += OnBookingChanged;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _bookings = await Api.GetMyBookingsAsync();
        _loading = false;
        StateHasChanged();
    }

    private void OnBookingChanged(Guid bookingId) => _ = InvokeAsync(LoadAsync);

    private async Task<Guid> CurrentUserId()
    {
        if (AuthState is null) return Guid.Empty;
        var user = (await AuthState).User;
        return Guid.TryParse(user.FindFirst(ClaimTypes.NameIdentifier)?.Value, out var id) ? id : Guid.Empty;
    }

    private string Counterpart(JobRequestDto b) =>
        b.ProviderUserId == _userId ? b.ClientName : (b.ProviderBusinessName ?? "Awaiting quotes");

    private string WhenLabel(JobRequestDto b)
    {
        var when = b.ConfirmedStartUtc ?? b.ProposedStartUtc;
        return when is { } d ? d.ToLocalTime().ToString("ddd d MMM, HH:mm") : "—";
    }

    private static string StatusLabel(JobStatus s) => s switch
    {
        JobStatus.Requested => "Gathering quotes",
        JobStatus.Quoted => "Quotes received",
        JobStatus.PendingProvider => "Awaiting provider",
        JobStatus.PendingClient => "Awaiting client",
        JobStatus.Scheduled => "Scheduled",
        JobStatus.InProgress => "In progress",
        JobStatus.Completed => "Awaiting payment",
        JobStatus.Paid => "Paid",
        JobStatus.Reviewed => "Reviewed",
        JobStatus.Cancelled => "Cancelled",
        JobStatus.Declined => "Declined",
        JobStatus.NoShow => "No-show",
        _ => s.ToString()
    };

    private static string StatusClass(JobStatus s) => s switch
    {
        JobStatus.Scheduled or JobStatus.InProgress => "avail-available",
        JobStatus.Paid or JobStatus.Reviewed => "avail-available",
        JobStatus.Completed => "emergency",
        JobStatus.Cancelled or JobStatus.Declined or JobStatus.NoShow => "avail-busy",
        _ => "verified"
    };

    public void Dispose() => Notifications.BookingChanged -= OnBookingChanged;
}
