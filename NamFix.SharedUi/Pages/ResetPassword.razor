@page "/reset-password"
@inject NamFixApiClient Api
@inject NavigationManager Nav

<PageTitle>Reset password — NamFix</PageTitle>

<div class="nf-form-card">
    <h2>Choose a new password</h2>
    @if (string.IsNullOrWhiteSpace(_token))
    {
        <p class="nf-error">This reset link is missing its token. Request a new link from the
            <a href="forgot-password">forgot password</a> page.</p>
    }
    else if (_done)
    {
        <p>Your password has been reset. You can now <a href="login">log in</a> with your new password.</p>
    }
    else
    {
        <EditForm Model="_model" OnValidSubmit="SubmitAsync">
            <DataAnnotationsValidator />
            <label>New password</label>
            <InputText @bind-Value="_model.NewPassword" type="password" />
            <label>Confirm new password</label>
            <InputText @bind-Value="_confirm" type="password" />

            @if (_error is not null)
            {
                <p class="nf-error">@_error</p>
            }
            <button class="nf-cta" type="submit" disabled="@_busy">@(_busy ? "…" : "Reset password")</button>
        </EditForm>
        <p class="nf-muted"><a href="login">Back to log in</a></p>
    }
</div>

@code {
    private readonly ResetPasswordWithTokenRequest _model = new();
    private string _confirm = "";
    private string? _token;
    private string? _error;
    private bool _busy;
    private bool _done;

    protected override void OnInitialized()
    {
        var query = Nav.ToAbsoluteUri(Nav.Uri).Query.TrimStart('?');
        foreach (var part in query.Split('&', StringSplitOptions.RemoveEmptyEntries))
        {
            var kv = part.Split('=', 2);
            if (kv.Length == 2 && kv[0] == "token")
            {
                _token = _model.Token = Uri.UnescapeDataString(kv[1]);
                break;
            }
        }
    }

    private async Task SubmitAsync()
    {
        _error = null;
        if (_model.NewPassword != _confirm)
        {
            _error = "The two passwords don't match.";
            return;
        }

        _busy = true;
        _error = await Api.ResetPasswordAsync(_model);
        _busy = false;
        if (_error is null) _done = true;
    }
}
